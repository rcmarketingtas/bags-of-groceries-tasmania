# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these in your Stripe dashboard
# Product: "Sponsor 1 Grocery Bag", Price: $25 AUD (one-time)
STRIPE_PRICE_FAMILY_BAG=price_...
# Promotion codes: create coupons in Stripe Dashboard → Products → Coupons,
# then add promotion codes. Checkout shows a promo field automatically (no extra env vars).
# Product: "Sponsor 2 Grocery Bags", Price: $50 AUD (one-time)
# STRIPE_PRICE_2_BAGS no longer used — single price model

# ─────────────────────────────────────────────
# Resend (https://resend.com)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
# Production: use a verified domain (add DNS records in Resend → Domains)
# Format: Display Name <email@yourdomain.com>  — no surrounding quotes in Vercel
RESEND_FROM_EMAIL=Bags of Groceries Tasmania <noreply@bagsofgroceries.org.au>
#
# SANDBOX / TEST DOMAINS (*.resend.app, onboarding@resend.dev):
# Resend ONLY delivers to the email address you signed up with until a domain
# is verified. Customer receipts (applicants, donors) will fail for other addresses.
# For local testing without a verified domain, set this to your Resend signup email
# and use that same address when testing applications/donations.
# RESEND_ACCOUNT_OWNER_EMAIL=you@example.com
#
# Your email(s) to receive new application, contact, and donation alerts.
# In sandbox mode this MUST be your Resend account email or admin alerts will also fail.
# Separate multiple addresses with a comma (no spaces required).
ADMIN_NOTIFY_EMAIL=you@example.com

# ─────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bags-of-groceries-tasmania.vercel.app

# ─────────────────────────────────────────────
# Upstash Redis (optional — for rate limiting)
# Create a free database at https://upstash.com
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
