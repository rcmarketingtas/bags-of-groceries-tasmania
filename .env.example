# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these in your Stripe dashboard
# Product: "Sponsor 1 Grocery Bag", Price: $25 AUD (one-time)
STRIPE_PRICE_1_BAG=price_...
# Product: "Sponsor 2 Grocery Bags", Price: $50 AUD (one-time)
STRIPE_PRICE_2_BAGS=price_...

# ─────────────────────────────────────────────
# Resend
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@bagsofgroceries.org.au

# ─────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bagsofgroceries.org.au

# ─────────────────────────────────────────────
# Upstash Redis (optional — for rate limiting)
# Create a free database at https://upstash.com
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
